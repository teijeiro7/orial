# ==========================================
# ORIAL APP - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ==========================================

# Firebase Google Sign-In
# Firebase Console → Project Settings → General → Your apps → Web app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Facebook Login
# developers.facebook.com → Your App → Settings → Basic
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN=

# WHOOP OAuth
# developer.whoop.com → Your App → Credentials
EXPO_PUBLIC_WHOOP_CLIENT_ID=

# App Configuration
EXPO_PUBLIC_APP_NAME=Orial
EXPO_PUBLIC_APP_SCHEME=orial

# Supabase (cloud backend + sync)
# Supabase Dashboard -> Project Settings -> API. The anon key is public-safe.
# Must use the EXPO_PUBLIC_ prefix to be readable at runtime via process.env.
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
